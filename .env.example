# ============================================
# Consolidador de Tenencias — Environment Variables
# ============================================

# --- NextAuth ---
NEXTAUTH_URL=http://localhost:3000   # en Vercel usar https://tu-dominio.com
NEXTAUTH_SECRET=          # openssl rand -base64 32

# --- Google OAuth (restringido a dominio corporativo) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAIL_DOMAIN=     # ej: tuempresa.com — solo emails de este dominio pueden loguearse

# --- Storage persistente (producción) ---
# Opción A: Vercel KV (legacy)
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
# Opción B: Upstash Redis (recomendada por Vercel Marketplace)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Opción C: Redis directo (URL única con credenciales embebidas)
REDIS_URL=
# También se aceptan alias automáticos de integraciones:
# - URL: UPSTASH_REDIS_REST_REDIS_URL o REDIS_URL
# - Token: UPSTASH_REDIS_REST_REDIS_TOKEN o REDIS_TOKEN

# --- Admin (Google) ---
ADMIN_EMAILS=             # comma-separated emails con rol admin, ej: admin@tuempresa.com,otro@tuempresa.com

# --- Usuarios locales (usuario/contraseña; sin Google o además de Google) ---
# JSON en una línea: hasta 10 usuarios. Cada uno tiene username, passwordHash (bcrypt) y admin (true/false).
# Generar hash en Node: node -e "console.log(require('bcryptjs').hashSync('TU_CLAVE', 10))"
# En .env.local (Next.js): cada $ del hash bcrypt debe ir como \$ (barra + $). Si no, Next expande $ como variable y el JSON falla. En Vercel (UI) pegá el hash con $ normal.
# Ejemplo:
# AUTH_LOCAL_USERS=[{"username":"admin","passwordHash":"\$2a\$10\$REEMPLAZAR","admin":true}]
AUTH_LOCAL_USERS=

# --- Calendario de bonos (export CSV Google Sheets; ver BOND_PAYMENTS_ENGINE_README.md) ---
BOND_PAYMENTS_URL=

# --- Google Drive ingestion (server-to-server para Vercel) ---
GOOGLE_DRIVE_FOLDER_ID=   # id de carpeta a monitorear
GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_DRIVE_SERVICE_ACCOUNT_PRIVATE_KEY=   # pegar con \n escapados

# --- Vercel Cron ---
CRON_SECRET=              # secreto para proteger /api/drive/sync?mode=cron
