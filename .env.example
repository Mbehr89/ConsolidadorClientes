# ============================================
# Consolidador de Tenencias — Environment Variables
# ============================================

# --- NextAuth ---
NEXTAUTH_URL=http://localhost:3000   # en Vercel usar https://tu-dominio.com
NEXTAUTH_SECRET=          # openssl rand -base64 32

# --- Google OAuth (restringido a dominio corporativo) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAIL_DOMAIN=     # ej: tuempresa.com — solo emails de este dominio pueden loguearse

# --- Vercel KV (solo para deploy; en dev local se usa mock in-memory) ---
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# --- Admin ---
ADMIN_EMAILS=             # comma-separated emails con rol admin, ej: admin@tuempresa.com,otro@tuempresa.com

# --- Google Drive ingestion (server-to-server para Vercel) ---
GOOGLE_DRIVE_FOLDER_ID=   # id de carpeta a monitorear
GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_DRIVE_SERVICE_ACCOUNT_PRIVATE_KEY=   # pegar con \n escapados

# --- Vercel Cron ---
CRON_SECRET=              # secreto para proteger /api/drive/sync?mode=cron
